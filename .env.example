# Copy to .env (or backend/.env) and fill in. Never commit .env.

# Django
SECRET_KEY=change-me-to-a-50-char-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,maverickstech.com.bd

# Postgres
DB_NAME=mavericks_tech
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Email (production SMTP — dev uses console backend)
# Configure further via /admin → Communications → EmailSettings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Public URL (for tracking pixels, email links)
BASE_URL=http://localhost:8000
