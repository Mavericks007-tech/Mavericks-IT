# Copy to .env (or backend/.env). Never commit secrets.

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------
ENVIRONMENT=development            # development | staging | production
DEBUG=True
SECRET_KEY=change-me-to-50-char-random-string-django-secret
ALLOWED_HOSTS=localhost,127.0.0.1,maverickstech.com.bd,www.maverickstech.com.bd
BASE_URL=http://localhost:8000
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Database (Postgres)
# ---------------------------------------------------------------------------
DB_ENGINE=postgres                 # postgres | sqlite
DB_NAME=mavericks_tech
DB_USER=mavericks
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=600

# ---------------------------------------------------------------------------
# CORS / CSRF (comma-separated)
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---------------------------------------------------------------------------
# Production security (only effective when DEBUG=False)
# ---------------------------------------------------------------------------
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# ---------------------------------------------------------------------------
# Rate limits (DRF throttling)
# ---------------------------------------------------------------------------
THROTTLE_ANON=60/min
THROTTLE_USER=1000/hour
THROTTLE_LOGIN=5/min
THROTTLE_PUBLIC_LEAD=10/hour
THROTTLE_MAGIC_LINK=5/hour

# ---------------------------------------------------------------------------
# Redis + Celery
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Email (SMTP). Leave EMAIL_HOST blank in dev to fall back to console backend.
# ---------------------------------------------------------------------------
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@maverickstech.com.bd

# ---------------------------------------------------------------------------
# AWS S3 (set USE_S3=True to enable media storage on S3)
# ---------------------------------------------------------------------------
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=mavericks-tech-media
AWS_S3_REGION_NAME=ap-southeast-1
AWS_S3_CUSTOM_DOMAIN=cdn.maverickstech.com.bd

# ---------------------------------------------------------------------------
# Sentry
# ---------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_TRACES_RATE=0.1

# ---------------------------------------------------------------------------
# Docker Postgres bootstrap
# ---------------------------------------------------------------------------
GUNICORN_WORKERS=3

# ---------------------------------------------------------------------------
# Frontend (next .env.local)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000
